<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/header') %>
<div class="container section">
  <h1>คำสั่งซื้อทั้งหมด</h1>
  <%- include('../partials/admin-tabs', { active: 'orders' }) %>
  <div class="card" style="padding:0;">
    <table>
      <thead><tr><th>#</th><th>ผู้ใช้</th><th>วันที่</th><th>ยอดรวม</th><th>สถานะ</th></tr></thead>
      <tbody>
        <% orders.forEach(function(o){ %>
          <tr>
            <td>#<%= o.id %></td>
            <td><%= o.username %></td>
            <td><%= o.created_at %></td>
            <td class="mono">฿<%= (o.total/100).toFixed(2) %></td>
            <td><span class="badge accent"><%= o.status %></span></td>
          </tr>
        <% }) %>
        <% if (orders.length === 0) { %><tr><td colspan="5">ยังไม่มีคำสั่งซื้อ</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
</body>
</html>
