<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/header') %>
<div class="container section">
  <h1>โค้ดเติมเงิน</h1>
  <%- include('../partials/admin-tabs', { active: 'topup' }) %>

  <div class="card" style="max-width:420px; margin-bottom:28px;">
    <h3>สร้างโค้ดเติมเงิน</h3>
    <form method="POST" action="/admin/topup-codes">
      <div class="field">
        <label>มูลค่าต่อโค้ด (บาท)</label>
        <input type="number" step="0.01" min="1" name="amount" required>
      </div>
      <div class="field">
        <label>จำนวนโค้ดที่ต้องการสร้าง</label>
        <input type="number" min="1" max="100" value="1" name="count" required>
      </div>
      <button class="btn btn-primary" type="submit">สร้างโค้ด</button>
    </form>
  </div>

  <div class="card" style="padding:0;">
    <table>
      <thead><tr><th>โค้ด</th><th>มูลค่า</th><th>สถานะ</th><th>สร้างเมื่อ</th></tr></thead>
      <tbody>
        <% codes.forEach(function(c){ %>
          <tr>
            <td class="mono"><%= c.code %></td>
            <td class="mono">฿<%= (c.amount/100).toFixed(2) %></td>
            <td><% if (c.used_by) { %><span class="badge warn">ใช้แล้ว</span><% } else { %><span class="badge accent">ยังไม่ใช้</span><% } %></td>
            <td><%= c.created_at %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
</body>
</html>
