<!DOCTYPE html>
<html lang="th">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/header') %>
<div class="container section">
  <h1>ประวัติการสั่งซื้อ</h1>
  <div class="card" style="padding:0; overflow:hidden;">
    <table>
      <thead><tr><th>คำสั่งซื้อ</th><th>วันที่</th><th>ยอดรวม</th><th>สถานะ</th><th></th></tr></thead>
      <tbody>
        <% orders.forEach(function(o){ %>
          <tr>
            <td>#<%= o.id %></td>
            <td><%= o.created_at %></td>
            <td class="mono">฿<%= (o.total/100).toFixed(2) %></td>
            <td><span class="badge accent"><%= o.status %></span></td>
            <td><a href="/orders/<%= o.id %>" class="btn btn-ghost btn-sm">ดูรายละเอียด</a></td>
          </tr>
        <% }) %>
        <% if (orders.length === 0) { %>
          <tr><td colspan="5">ยังไม่มีคำสั่งซื้อ</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
</body>
</html>
