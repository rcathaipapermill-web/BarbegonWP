PORT=3000
JWT_SECRET=change-this-to-a-long-random-string

# --- Production database (leave blank for local development) ---
# For local dev, the app defaults to a plain SQLite file at ./data/shop.db
# and these two variables are not needed.
#
# For deploying to a host with no persistent disk on the free tier (e.g. Render),
# create a free database at https://turso.tech and put its values here instead,
# so your data survives restarts/redeploys. See README.md for the full steps.
# DATABASE_URL=libsql://your-db-name-yourorg.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token
